@{
    ViewData["Title"] = "Panel de Control";
}

<div class="text-center mt-5">
    <h1 class="display-4">Sistema de Control de Drones</h1>
    <p>Ministerio de la Defensa de Guatemala</p>
</div>

<div class="container mt-4">
    @if (ViewBag.MensajeExito != null)
    {
        <div class="alert alert-success">@ViewBag.MensajeExito</div>
    }
    @if (ViewBag.MensajeError != null)
    {
        <div class="alert alert-danger">@ViewBag.MensajeError</div>
    }

    <div class="card shadow-sm p-4">
        <h3>Cargar Configuración</h3>
        <p>Selecciona el archivo <code>entrada.xml</code> para configurar los drones, sistemas y mensajes.</p>

        <form asp-controller="Home" asp-action="CargarArchivo" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <input class="form-control" type="file" name="archivoXml" accept=".xml" required />
            </div>
            <button type="submit" class="btn btn-primary">Cargar Archivo</button>
            <a asp-controller="Home" asp-action="Inicializar" class="btn btn-warning">Inicializar Sistema</a>
            <hr class="my-4">
            <div class="d-grid gap-2 col-6 mx-auto">
                <a asp-controller="Home" asp-action="ListadoDrones" class="btn btn-info btn-lg">Ver Listado de
                    Drones</a>
            </div>
            <div class="d-grid gap-2 col-6 mx-auto mt-2"></div>
            <a asp-controller="Home" asp-action="GraficaSistemas" class="btn btn-success btn-lg">Ver Gráfica de
                Sistemas</a>
            <a asp-controller="Home" asp-action="ListadoMensajes" class="btn btn-primary btn-lg">Gestión de Mensajes</a>
        </form>
    </div>

</div>
</div>