@{
    ViewData["Title"] = "Gráfica de Sistemas de Drones";
}

<div class="container mt-4">
    <h2 class="mb-4"> Gráfica de Sistemas de Drones</h2>
    
    <div class="card shadow-sm p-4 text-center">
        <p class="text-muted">Desplázate y haz zoom sobre el gráfico para ver los detalles.</p>
        
       <div id="graficoGraphviz" style="width: 100%; height: 600px; border: 1px solid #ddd; border-radius: 8px; overflow: auto;"></div>  
       
        <div class="mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Volver al Inicio</a>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/viz.js/2.1.2/viz.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/viz.js/2.1.2/full.render.js"></script>

<script>
    var dotString = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.CodigoDot));

    if (dotString && dotString.trim() !== "") {
        var viz = new Viz();
        
        viz.renderSVGElement(dotString)
           .then(function(element) {
               var contenedor = document.getElementById("graficoGraphviz");
               contenedor.innerHTML = ""; 
               
               element.style.maxWidth = "none";
               element.style.height = "auto";
               
               contenedor.appendChild(element);
           })
           .catch(error => {
               console.error("Error dibujando la gráfica:", error);
               document.getElementById("graficoGraphviz").innerHTML = "<p class='mt-5 text-danger'>Hubo un error al renderizar la gráfica.</p>";
           });
    } else {
        document.getElementById("graficoGraphviz").innerHTML = "<p class='mt-5 text-danger'>No hay datos para graficar.</p>";
    }
</script>