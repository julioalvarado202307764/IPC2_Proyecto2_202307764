@model Proyecto2.Models.ListaDrones
@{
    ViewData["Title"] = "Gestión de Drones";
    var actual = Model?.Cabeza; 
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="display-6 fw-bolder text-dark"> Gestión de Drones Tácticos</h2>
        <p class="text-muted fs-5">Registro y control alfabético del escuadrón</p>
    </div>

    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mx-auto" style="max-width: 800px;" role="alert">
            <strong>¡Confirmado!</strong> @TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mx-auto" style="max-width: 800px;" role="alert">
            <strong>Alerta:</strong> @TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-success text-white py-3">
                    <h5 class="mb-0 fw-bold"> Dar de Alta Nuevo Dron</h5>
                </div>
                <div class="card-body bg-light d-flex flex-column justify-content-center p-4">
                    <p class="text-muted small mb-4">Ingrese el nombre del nuevo dron. El sistema validará que sea único y lo insertará ordenado alfabéticamente.</p>
                    
                    <form asp-controller="Home" asp-action="AgregarDron" method="post">
                        <div class="mb-3">
                            <label for="nombreDron" class="form-label fw-bold">Identificador del Dron:</label>
                            <input type="text" id="nombreDron" name="nombreDron" class="form-control form-control-lg border-success" placeholder="Ej: DronExplorador" required>
                        </div>
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">Registrar en Escuadrón</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8 mb-4">
            <div class="card shadow-lg border-0 h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0 fw-bold"> Escuadrón Activo Registrado</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                        <table class="table table-striped table-hover align-middle mb-0">
                            <thead class="table-secondary sticky-top">
                                <tr>
                                    <th scope="col" class="text-center" style="width: 15%;">No.</th>
                                    <th scope="col" class="px-4">Nombre del Dron</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (actual == null)
                                {
                                    <tr>
                                        <td colspan="2" class="text-center text-muted py-5">
                                            <i class="fs-1">🪫</i><br>
                                            No hay drones en el escuadrón.<br>Sube un archivo XML o ingresa uno manual.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    int contador = 1;
                                    while (actual != null)
                                    {
                                        <tr>
                                            <td class="text-center fw-bold text-muted">@contador</td>
                                            <td class="px-4"><span class="badge bg-primary rounded-pill px-3 py-2 fs-6 shadow-sm">@actual.DronInfo.Nombre</span></td>
                                        </tr>
                                        actual = actual.Siguiente;
                                        contador++;
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="text-center mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-lg px-5 shadow-sm">Volver al Panel Principal</a>
    </div>
</div>